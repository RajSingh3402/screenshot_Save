// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 1. Websites Model
model Website {
  id               BigInt  @id
  name             String  @db.VarChar(255)
  url              String  @db.VarChar(2048)
  status           String  @default("active") @db.VarChar(50)
  lastStatus       String? @db.VarChar(50)
  lastCapture      String? @db.VarChar(50)
  error            String? @db.Text
  lastCaptureImage String? @db.VarChar(255)

  @@map("websites")
}

// 2. Reports Model
model Report {
  id      BigInt         @id
  date    String         @db.VarChar(50)
  time    String         @db.VarChar(50)
  total   Int
  success Int
  failed  Int
  file    String         @db.VarChar(255)
  details ReportDetail[]

  @@map("reports")
}

// 3. Report Details Model
model ReportDetail {
  id         Int     @id @default(autoincrement())
  reportId   BigInt  @map("report_id")
  websiteId  BigInt  @map("website_id")
  name       String  @db.VarChar(255)
  url        String  @db.VarChar(2048)
  status     String  @db.VarChar(50)
  loadTime   Int?
  error      String? @db.Text
  screenshot String? @db.VarChar(255)
  report     Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId], map: "idx_report_details_report_id")
  @@map("report_details")
}

// 4. Users Model
model User {
  id      BigInt @id
  name    String @db.VarChar(255)
  email   String @db.VarChar(255)
  role    String @default("Viewer") @db.VarChar(100)
  status  String @default("active") @db.VarChar(50)
  created String @db.VarChar(50)

  @@map("users")
}

// 5. Schedules Model
model Schedule {
  id      BigInt  @id
  time    String  @db.VarChar(5)
  enabled Boolean @default(true)

  @@map("schedules")
}

// 6. Email Recipients Model
model EmailRecipient {
  id    BigInt @id
  email String @db.VarChar(255)

  @@map("email_recipients")
}

// 7. SMTP Settings Model
model SmtpSetting {
  id   Int     @id @default(1)
  host String? @db.VarChar(255)
  port String? @db.VarChar(50)
  user String? @db.VarChar(255)
  pass String? @db.VarChar(255)

  @@map("smtp_settings")
}
